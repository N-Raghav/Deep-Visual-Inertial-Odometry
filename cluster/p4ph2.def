Bootstrap: docker
From: ubuntu:24.04

%labels
    Maintainer  P4Ph2
    Blender     5.1.0
    Purpose     IMU/trajectory sim + GPU Blender rendering on HPC

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates wget xz-utils git build-essential \
        python3 python3-pip python3-dev python3-venv \
        libxi6 libxxf86vm1 libxfixes3 libxrender1 libxkbcommon0 \
        libsm6 libxext6 libx11-6 libxrandr2 libxcursor1 libxinerama1 \
        libxcomposite1 libxdamage1 libxtst6 libdbus-1-3 \
        libfontconfig1 libfreetype6 libgl1 libegl1 libglx0 libgles2 \
        libvulkan1 vulkan-tools mesa-vulkan-drivers \
        libnvidia-egl-wayland1 \
        ocl-icd-libopencl1 \
        zlib1g libtinfo6
    rm -rf /var/lib/apt/lists/*

    # ---- Blender 5.1.0 (matches what's in the host repo) ----
    cd /opt
    BLENDER_TARBALL=blender-5.1.0-linux-x64.tar.xz
    wget -q https://download.blender.org/release/Blender5.1/${BLENDER_TARBALL}
    tar -xf ${BLENDER_TARBALL}
    rm ${BLENDER_TARBALL}
    ln -s /opt/blender-5.1.0-linux-x64/blender /usr/local/bin/blender

    # ---- System Python deps for generate_imu.py ----
    python3 -m pip install --no-cache-dir --break-system-packages \
        "numpy<2.3" "scipy<1.16" matplotlib pillow

    # ---- gnss-ins-sim from upstream ----
    cd /opt
    git clone --depth 1 https://github.com/Aceinna/gnss-ins-sim.git
    cd gnss-ins-sim
    python3 -m pip install --no-cache-dir --break-system-packages .

    # ---- Vulkan ICD for NVIDIA.
    # Apptainer's --nv bind-mounts libGLX_nvidia.so.0 into /.singularity.d/libs/
    # (which is on LD_LIBRARY_PATH) but does NOT mount the ICD JSON. We write
    # one that references the lib by soname; the loader will then find it.
    mkdir -p /etc/vulkan/icd.d /etc/vulkan/implicit_layer.d
    cat > /etc/vulkan/icd.d/nvidia_icd.json <<'EOF'
{
    "file_format_version" : "1.0.0",
    "ICD": {
        "library_path": "libGLX_nvidia.so.0",
        "api_version" : "1.3.277"
    }
}
EOF

    # ---- Sanity: Blender headless launch ----
    blender --version

%environment
    export PATH=/opt/blender-5.1.0-linux-x64:/usr/local/bin:${PATH}
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # Ask the NVIDIA container hooks (and Apptainer --nv) for full GPU caps.
    export NVIDIA_DRIVER_CAPABILITIES=compute,graphics,utility,video
    export NVIDIA_VISIBLE_DEVICES=all
    # Vulkan loader: explicit path to our baked-in NVIDIA ICD.
    export VK_ICD_FILENAMES=/etc/vulkan/icd.d/nvidia_icd.json
    # Some Blender + Vulkan setups try to write to XDG_RUNTIME_DIR.
    export XDG_RUNTIME_DIR=/tmp

%runscript
    # Default: drop into bash. Args are exec'd if given, e.g.
    #   apptainer run --nv p4ph2.sif blender --version
    if [ "$#" -eq 0 ]; then
        exec /bin/bash
    else
        exec "$@"
    fi

%apprun imu
    # Run the IMU/trajectory generator.
    # Usage: apptainer run --app imu p4ph2.sif --out /data/run_001 --traj figure8
    exec python3 /workspace/data_generation/generate_imu.py "$@"

%apprun render
    # Run the Blender GPU render.
    # Usage: apptainer run --nv --app render p4ph2.sif --data /data/run_001 --textures /data/textures
    exec blender --background --gpu-backend vulkan \
        --python /workspace/data_generation/blender_render.py -- "$@"

%apprun batch
    # Run the full batch script (generate IMU + render for all trajectories).
    # Usage: apptainer run --nv --app batch p4ph2.sif /data /data/textures
    exec /workspace/data_generation/generate_batch.sh "$@"

%help
    P4Ph2 simulation container.

    Build (rootless, fakeroot):
        apptainer build --fakeroot p4ph2.sif p4ph2.def

    Run with GPU (Vulkan via NVIDIA --nv):
        apptainer run --nv \
            --bind /path/to/P4Ph2:/workspace \
            --bind /path/to/data:/data \
            p4ph2.sif

    Render a sequence:
        apptainer run --nv \
            --bind /path/to/P4Ph2:/workspace \
            --bind /path/to/data:/data \
            --app render p4ph2.sif \
            --data /data/run_001 --textures /data/textures

    Notes:
      * --nv bind-mounts the host NVIDIA driver libs and ICD; required for GPU.
      * Bind the repo at /workspace so the data_generation/ scripts are visible.
      * Bind your data directory at /data (or anywhere; pass paths explicitly).
